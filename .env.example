# ============================================================================
# .env — секреты и конфиг для tutor_site.
# Скопируй этот файл в `.env` (без .example) и заполни значения.
# Файл .env НЕ коммитится в git (см. .gitignore).
# ============================================================================

# --- ВЫБОР СРЕДЫ ----------------------------------------------------------
# Локально: DJANGO_DEBUG=True (или не задавать вообще — True по умолчанию).
# На сервере: DJANGO_DEBUG=False
DJANGO_DEBUG=True

# --- СЕКРЕТНЫЙ КЛЮЧ -------------------------------------------------------
# Сгенерировать новый:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# На сервере ОБЯЗАТЕЛЬНО заменить значение по умолчанию.
SECRET_KEY=django-insecure-change-me-in-production

# --- ХОСТЫ И CSRF ---------------------------------------------------------
# Список через запятую, без пробелов и схемы (только домены).
# Локально можно не задавать (по умолчанию 127.0.0.1,localhost).
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Для прода:
# DJANGO_ALLOWED_HOSTS=zenchenkoim.ru,www.zenchenkoim.ru

# Список через запятую, СО СХЕМОЙ https://. Только для прода.
DJANGO_CSRF_TRUSTED_ORIGINS=
# Для прода:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://zenchenkoim.ru,https://www.zenchenkoim.ru

# --- БАЗА ДАННЫХ ----------------------------------------------------------
# Локально: пусто → используется db.sqlite3.
# На сервере (PostgreSQL):
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# --- HSTS (опционально) ---------------------------------------------------
# По умолчанию 31536000 (год). При первом деплое ставь 60, проверь что https
# работает корректно, потом подними до 31536000.
# DJANGO_HSTS_SECONDS=60

# --- УРОВЕНЬ ЛОГИРОВАНИЯ --------------------------------------------------
# DEBUG / INFO / WARNING / ERROR. На проде можно WARNING.
DJANGO_LOG_LEVEL=INFO
